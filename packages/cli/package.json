{
	"name": "@hubble.md/cli",
	"version": "0.0.1",
	"license": "MIT",
	"type": "module",
	"bin": {
		"hubble": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"postbuild": "chmod +x dist/index.js",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"dev": "tsc -p tsconfig.json --watch --preserveWatchOutput"
	},
	"dependencies": {
		"@hubble.md/convex-client": "workspace:*",
		"@hubble.md/sync": "workspace:*",
		"@hubble.md/sync-backend": "workspace:*",
		"@tailwindcss/vite": "^4.1.18",
		"@vitejs/plugin-react": "^4.7.0",
		"chokidar": "^4.0.3",
		"convex": "^1.34.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwindcss": "^4.1.18",
		"vite": "^7.3.1"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"typescript": "~5.8.3"
	}
}
